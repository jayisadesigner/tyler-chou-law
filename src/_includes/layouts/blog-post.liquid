---
layout: base.liquid
---
<article class="blog-post">
  <section class="hero hero--inner-page hero--blog-post section section-reveal">
    {% if featured_image %}
      <div class="background-image"{% if image_object_position %} data-object-position="{{ image_object_position }}"{% endif %}>
        <img
          class="background-image__img"
          src="{{ featured_image }}"
          alt="{{ image_alt | default: title }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        {% include "partials/background-overlay.liquid" %}
      </div>
    {% endif %}

    <div class="hero-content hero-content--inner-page hero-content--blog-post">
      <div class="hero-headline-wrapper">
        <p class="blog-post__meta">
          <time datetime="{{ page.date | isoDate }}">{{ page.date | formatDate }}</time>
          {% if author %} · {{ author }}{% endif %}
          {% if reading_time %} · {{ reading_time }} min read{% endif %}
        </p>
        <h1 class="blog-post__title hero-headline hero-headline--inner-page line-animate">{{ title | line_animate }}</h1>
        {% if description %}
          <p class="blog-post__description hero-subheadline hero-subheadline--inner-page text-large">{{ description }}</p>
        {% endif %}
      </div>
    </div>
  </section>

  <div class="blog-post__body section section-reveal">
    <div class="container container-narrow">
      <div class="prose">
        {{ content }}
      </div>
    </div>
  </div>

  <footer class="blog-post__footer section section-reveal">
    <div class="container container-narrow">
      <p class="blog-post__author-bio">{{ site.bio.canonical }}</p>
      <div class="blog-post__cta">
        <a href="/contact/" class="btn btn--secondary btn--on-dark btn--chuparosa">Work With Tyler</a>
        <a href="/love-letters/" class="btn btn--ghost btn--on-dark btn--chuparosa">More Love Letters</a>
      </div>
    </div>
  </footer>
</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "datePublished": "{{ page.date | isoDate }}",
  "dateModified": "{{ updated | default: page.date | isoDate }}",
  "author": { "@id": "{{ site.url }}/#tyler-chou" },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.name }}",
    "logo": { "@type": "ImageObject", "url": "{{ site.monogram | absolute_url: site.url }}" }
  },
  "description": "{{ description }}",
  "mainEntityOfPage": "{{ page.url | absolute_url: site.url }}"{% if featured_image %},
  "image": "{{ featured_image | absolute_url: site.url }}"{% endif %}
}
</script>
