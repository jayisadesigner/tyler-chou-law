<div class="client-card client-card--testimonial" role="listitem">
  {% if t.image %}
    <div class="client-card__image-wrapper">
      <img class="client-card__image" src="{{ t.image }}" alt="{{ t.alt | default: t.name }}" loading="lazy" decoding="async" />
      <div class="client-card__overlay" aria-hidden="true"></div>
      <div class="client-card__scrim" aria-hidden="true"></div>
    </div>
  {% endif %}
  <div class="client-card__content">
    <div class="client-card__meta">
      <p class="client-card__name">{{ t.name }}</p>
      {% if t.handle %}<p class="client-card__handle">{{ t.handle }}</p>{% endif %}
      {% if t.stats %}<p class="client-card__stats">{{ t.stats }}</p>{% endif %}
    </div>
    <p class="client-card__quote text-large">{{ t.quote }}</p>
  </div>
</div>
