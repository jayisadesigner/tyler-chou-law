{% assign rl = block | default: include %}
{% assign rl_layout = rl.layout | default: "right" %}
{% assign show_overlay = rl.media.overlay %}
{% if show_overlay == nil %}{% assign show_overlay = true %}{% endif %}

<section class="content-section{% if rl_layout == 'left' %} content-section--media-left{% endif %} content-section--parallax section section-reveal">
  <div class="content-section__container">
    <div class="content-section__content">
      <div class="content-section__headline">
        <h2 class="content-section__headline-text line-animate">{{ rl.headline | line_animate }}</h2>
      </div>
      {% if rl.intro %}
        <div class="content-section__body">
          {% for p in rl.intro %}<p>{{ p.text }}</p>{% endfor %}

          {% for group in rl.groups %}
            <h3 class="roster-list__headline">{{ group.title }}</h3>
            <div class="roster-list">
              {% for item in group.items %}
                {% if item.url %}
                  <a class="roster-list__item" href="{{ item.url }}">
                    {% if item.handle %}<span class="roster-list__handle">{{ item.handle }}</span>{% endif %}
                    {% if item.name %}<span class="roster-list__name">{{ item.name }}</span>{% endif %}
                  </a>
                {% else %}
                  <div class="roster-list__item">
                    {% if item.handle %}<span class="roster-list__handle">{{ item.handle }}</span>{% endif %}
                    {% if item.name %}<span class="roster-list__name">{{ item.name }}</span>{% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {% if rl.media and rl.media.image %}
      <div class="content-section__media">
        <div class="background-image{% unless show_overlay %} background-image--no-overlay{% endunless %}">
          <img class="background-image__img" src="{{ rl.media.image }}" alt="{{ rl.media.image_alt }}" loading="lazy" decoding="async" />
          {% if show_overlay %}
            <div class="background-image__overlay-top"></div>
            <div class="background-image__overlay-bottom"></div>
            <div class="background-image__overlay-left"></div>
            <div class="background-image__overlay-right"></div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</section>
