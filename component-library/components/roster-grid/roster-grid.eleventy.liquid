{% assign rg = block | default: include %}
{% assign rg_source = rg.source | default: "collection" %}
{% assign rg_creators = rg.manual_creators %}
{% if rg_source == "collection" and roster %}
  {% assign rg_creators = roster %}
{% elsif rg_source == "featured" and roster %}
  {% assign rg_creators = roster | where: "featured", true %}
{% endif %}

<section class="section-grid section-grid--roster section section-reveal">
  <div class="section-grid__container">
    {% if rg.headline or rg.link.url %}
      <div class="section-grid__header">
        {% if rg.headline %}
          <div class="section-grid__headline">
            <h2 class="content-section__headline-text line-animate">{{ rg.headline | line_animate }}</h2>
          </div>
        {% endif %}
        {% if rg.link and rg.link.label and rg.link.url %}
          <a class="section-grid__link" href="{{ rg.link.url }}">{{ rg.link.label }}</a>
        {% endif %}
      </div>
    {% endif %}

    <div class="section-grid__grid">
      {% if rg.limit %}
        {% assign rg_show = rg_creators | slice: 0, rg.limit %}
      {% else %}
        {% assign rg_show = rg_creators %}
      {% endif %}
      {% for c in rg_show %}
        <a class="roster-card" href="{{ c.url | default: c.profile_url }}"{% if c.external %} target="_blank" rel="noopener noreferrer"{% endif %}>
          <div class="roster-card__image-wrapper">
            <img class="roster-card__image" src="{{ c.image }}" alt="{{ c.alt | default: c.handle }}" loading="lazy" decoding="async" />
            <div class="roster-card__overlay" aria-hidden="true"></div>
            <div class="roster-card__scrim" aria-hidden="true"></div>
          </div>
          <p class="roster-card__handle">{{ c.handle }}</p>
        </a>
      {% endfor %}
    </div>
  </div>
</section>
