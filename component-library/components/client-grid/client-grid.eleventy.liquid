{% assign cg = block | default: include %}
{% assign cg_source = cg.source | default: "collection" %}
{% assign cg_creators = cg.manual_creators %}
{% if cg_source == "collection" and clients %}
  {% assign cg_creators = clients %}
{% elsif cg_source == "featured" and clients %}
  {% assign cg_creators = clients | where: "featured", true %}
{% endif %}

<section class="section-grid section-grid--clients section section-reveal">
  <div class="section-grid__container">
    {% if cg.headline or cg.link.url %}
      <div class="section-grid__header">
        {% if cg.headline %}
          <div class="section-grid__headline">
            <h2 class="content-section__headline-text line-animate">{{ cg.headline | line_animate }}</h2>
          </div>
        {% endif %}
        {% if cg.link and cg.link.label and cg.link.url %}
          <a class="section-grid__link" href="{{ cg.link.url }}">{{ cg.link.label }}</a>
        {% endif %}
      </div>
    {% endif %}

    <div class="section-grid__grid">
      {% if cg.limit %}
        {% assign cg_show = cg_creators | slice: 0, cg.limit %}
      {% else %}
        {% assign cg_show = cg_creators %}
      {% endif %}
      {% for c in cg_show %}
        <a class="client-card{% if c.external %} client-card--external{% endif %}" href="{{ c.url | default: c.profile_url }}"{% if c.external %} target="_blank" rel="noopener noreferrer"{% endif %}>
          <div class="client-card__image-wrapper">
            <img class="client-card__image" src="{{ c.image }}" alt="{{ c.alt | default: c.handle }}" loading="lazy" decoding="async" />
            <div class="client-card__overlay" aria-hidden="true"></div>
            <div class="client-card__scrim" aria-hidden="true"></div>
            {% if c.external %}
              {% include "partials/external-icon.liquid" icon_class: "client-card__external-icon" %}
              <span class="visually-hidden"> (opens in new tab)</span>
            {% endif %}
          </div>
          <p class="client-card__handle">{{ c.handle }}</p>
        </a>
      {% endfor %}
    </div>
  </div>
</section>
